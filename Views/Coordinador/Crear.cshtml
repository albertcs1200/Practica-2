@model PortalUniversidad.Models.Curso

@{
    ViewData["Title"] = "Crear Curso";
}

<h1>Crear Curso</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Crear">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Codigo" class="form-label"></label>
                <input asp-for="Codigo" class="form-control" />
                <span asp-validation-for="Codigo" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Creditos" class="form-label"></label>
                    <input asp-for="Creditos" class="form-control" type="number" min="1" />
                    <span asp-validation-for="Creditos" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CupoMaximo" class="form-label">Cupo Máximo</label>
                    <input asp-for="CupoMaximo" class="form-control" type="number" min="1" />
                    <span asp-validation-for="CupoMaximo" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="HorarioInicio" class="form-label">Horario Inicio</label>
                    <input asp-for="HorarioInicio" class="form-control" type="time" />
                    <span asp-validation-for="HorarioInicio" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="HorarioFin" class="form-label">Horario Fin</label>
                    <input asp-for="HorarioFin" class="form-control" type="time" />
                    <span asp-validation-for="HorarioFin" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3 form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Activo" /> @Html.DisplayNameFor(model => model.Activo)
                </label>
            </div>
            
            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Crear</button>
                <a asp-action="Index" class="btn btn-secondary">Volver al Panel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
