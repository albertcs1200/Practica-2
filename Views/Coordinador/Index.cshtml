@model IEnumerable<PortalUniversidad.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador";
}

<h1 class="mb-4">Panel de Coordinador - Gestión de Cursos</h1>

<p>
    <a asp-action="Crear" class="btn btn-primary">Crear Nuevo Curso</a>
</p>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Cupo</th>
            <th>Horario</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Codigo</td>
            <td>@item.Nombre</td>
            <td>@item.Creditos</td>
            <td>@item.CupoMaximo</td>
            <td>@item.HorarioInicio.ToString(@"hh\:mm") - @item.HorarioFin.ToString(@"hh\:mm")</td>
            <td>
                @if(item.Activo)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactivo</span>
                }
            </td>
            <td>
                <div class="d-flex gap-2">
                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Editar</a>
                    <a asp-action="Matriculas" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Matrículas</a>
                    
                    <form asp-action="AlternarEstado" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@item.Id" />
                        @if (item.Activo)
                        {
                            <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-sm btn-outline-success">Activar</button>
                        }
                    </form>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>
